# --- DATABASE ---
# Cung cấp bởi Neon (Serverless Postgres). 
# Hãy thay thế bằng chuỗi kết nối thực tế trên Dashboard Neon. Tránh dùng URL IPv4 cũ, hãy dùng pooler URL có chữ `pooler` hoặc kết nối SSL trực tiếp.
DATABASE_URL="postgresql://user:password@neon-host.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- AUTHENTICATION ---
# Chuỗi hash bảo mật cho NextAuth (Chạy lệnh `openssl rand -base64 32` để gen).
NEXTAUTH_SECRET="your_super_secret_string_here_32_chars"

# Địa chỉ Web của bạn, Vercel đôi khi tự sinh nhưng tốt nhất ép cứng.
NEXTAUTH_URL="https://anmenh.vutera.net" 
# Nếu chạy ở máy local thì là: "http://localhost:3000" (hoặc 3001 tùy port)

# --- AI & AUTOMATION ---
# Mã khóa API tử OpenAI để bộ xử lý xin quẻ. Tiền phí được tính trên tài khoản OpenAI này.
OPENAI_API_KEY="sk-proj-xxxxxxx"

# Mật khẩu mà Vercel Cron sẽ gửi lên Server của bạn mỗi khi báo thức gọi AI chạy ngầm hằng đêm. 
# Tránh người ngoài biết URL và gọi trộm gây tốn tiền OpenAI. Bịa ngẫu nhiên: Vd: "QoP_My_SeCrEt_123"
CRON_SECRET="your_cron_secret"

# -----------------
# HƯỚNG DẪN DÙNG (Cho Dev Local): Lấy file này copy thành 3 file .env:
# 1. Để ở root /
# 2. Để ở /apps/anmenh-web/.env
# 3. Để ở /packages/database/.env
# Chạy lệnh Cập nhật DB gốc:
# pnpm --filter database exec prisma db push
